@model IEnumerable<TechMoveGLMS.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2" style="color: #FF6B8A;"></i>Client Management</h2>
    <a asp-action="Create" class="btn-gradient">
        <i class="fas fa-plus-circle me-2"></i>Add New Client
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-users fa-3x text-muted mb-3"></i>
        <h4>No clients yet</h4>
        <p>Click the button above to add your first client</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th><i class="fas fa-building me-1"></i> Company Name</th>
                    <th><i class="fas fa-envelope me-1"></i> Email</th>
                    <th><i class="fas fa-phone me-1"></i> Phone</th>
                    <th><i class="fas fa-map-marker-alt me-1"></i> Region</th>
                    <th><i class="fas fa-cogs me-1"></i> Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td><strong>@client.Name</strong></td>
                        <td>@client.Email</td>
                        <td>@client.Phone</td>
                        <td><span class="badge" style="background: #9B59B6;">@client.Region</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@client.ClientId" class="btn btn-sm me-1" title="View" style="background: #FF6B8A; color: white;">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-sm me-1" title="Edit" style="background: #FF9F43; color: white;">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@client.ClientId" class="btn btn-sm" title="Delete" style="background: #E84393; color: white;">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}