@model TechMoveGLMS.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="text-center mb-4">
            <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
            <h2 class="mt-2">Delete Client</h2>
            <p class="text-muted">Are you sure you want to delete this client?</p>
        </div>

        <div class="alert alert-danger">
            <i class="fas fa-warning me-2"></i>
            <strong>Warning!</strong> This action cannot be undone.
        </div>

        <div class="stat-card">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Company Name</label>
                        <p class="fs-5">@Model.Name</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Region</label>
                        <p><span class="badge bg-info">@Model.Region</span></p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Email</label>
                        <p>@Model.Email</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">Phone</label>
                        <p>@Model.Phone</p>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ClientId" />
                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Index" class="btn btn-secondary me-md-2">
                        <i class="fas fa-times me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Delete Permanently
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>