@model TechMoveGLMS.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-building me-2 text-primary"></i>Client Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn-outline-gradient me-2">
            <i class="fas fa-edit me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn-gradient">
            <i class="fas fa-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-icon mb-3">
                <i class="fas fa-building"></i>
            </div>
            <h4>@Model.Name</h4>
            <hr>
            <table class="table table-borderless">
                <tr>
                    <th style="width: 120px;"><i class="fas fa-envelope me-2"></i>Email:</th>
                    <td>@Model.Email</td>
                </tr>
                <tr>
                    <th><i class="fas fa-phone me-2"></i>Phone:</th>
                    <td>@Model.Phone</td>
                </tr>
                <tr>
                    <th><i class="fas fa-map-marker-alt me-2"></i>Region:</th>
                    <td><span class="badge bg-info">@Model.Region</span></td>
                </tr>
            </table>
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-icon mb-3" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                <i class="fas fa-file-contract"></i>
            </div>
            <h4>Contracts</h4>
            <hr>
            @if (Model.Contracts != null && Model.Contracts.Any())
            {
                <div class="list-group">
                    @foreach (var contract in Model.Contracts)
                    {
                        <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.ContractId" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-file-signature me-2"></i>
                                    <strong>@contract.ServiceLevel</strong> - @contract.Status
                                </div>
                                <span class="badge bg-primary">@contract.StartDate.ToString("dd MMM yyyy")</span>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No contracts yet for this client.</p>
                <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@Model.ClientId" class="btn-outline-gradient btn-sm">
                    <i class="fas fa-plus-circle me-1"></i>Create Contract
                </a>
            }
        </div>
    </div>
</div>