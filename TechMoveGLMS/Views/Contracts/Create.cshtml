@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
    var clients = ViewBag.Clients as IEnumerable<TechMoveGLMS.Models.Client>;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="text-center mb-4">
            <i class="fas fa-file-signature fa-3x text-primary"></i>
            <h2 class="mt-2">Create New Contract</h2>
            <p class="text-muted">Fill in the contract details below</p>
        </div>

        <div class="stat-card">
            <form asp-action="Create" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label fw-bold">
                        <i class="fas fa-building me-1"></i>Select Client
                    </label>
                    <select asp-for="ClientId" class="form-control form-control-modern" asp-items="@(new SelectList(clients, "ClientId", "Name"))">
                        <option value="">-- Select Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label fw-bold">
                                <i class="fas fa-calendar-alt me-1"></i>Start Date
                            </label>
                            <input asp-for="StartDate" type="date" class="form-control form-control-modern" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label fw-bold">
                                <i class="fas fa-calendar-check me-1"></i>End Date
                            </label>
                            <input asp-for="EndDate" type="date" class="form-control form-control-modern" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ServiceLevel" class="form-label fw-bold">
                                <i class="fas fa-chart-line me-1"></i>Service Level
                            </label>
                            <select asp-for="ServiceLevel" class="form-control form-control-modern">
                                <option value="">Select Level</option>
                                <option value="Basic">Basic</option>
                                <option value="Standard">Standard</option>
                                <option value="Premium">Premium</option>
                                <option value="Enterprise">Enterprise</option>
                            </select>
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold">
                                <i class="fas fa-tag me-1"></i>Status
                            </label>
                            <select asp-for="Status" class="form-control form-control-modern">
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                                <option value="OnHold">On Hold</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="signedAgreement" class="form-label fw-bold">
                        <i class="fas fa-file-pdf me-1"></i>Signed Agreement (PDF only)
                    </label>
                    <input type="file" name="signedAgreement" class="form-control form-control-modern" accept=".pdf" />
                    <small class="text-muted">Only PDF files are accepted. Max size: 10MB</small>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Index" class="btn btn-secondary me-md-2">
                        <i class="fas fa-times me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn-gradient">
                        <i class="fas fa-save me-1"></i>Create Contract
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}