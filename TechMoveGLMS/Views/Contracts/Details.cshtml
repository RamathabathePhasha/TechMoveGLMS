@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-file-contract me-2 text-primary"></i>Contract Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn-outline-gradient me-2">
            <i class="fas fa-edit me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn-gradient">
            <i class="fas fa-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="stat-card">
            <h5><i class="fas fa-building me-2 text-primary"></i>Client Information</h5>
            <hr>
            @if (Model.Client != null)
            {
                <p><strong>Client Name:</strong> @Model.Client.Name</p>
                <p><strong>Email:</strong> @Model.Client.Email</p>
                <p><strong>Phone:</strong> @Model.Client.Phone</p>
                <p><strong>Region:</strong> <span class="badge bg-info">@Model.Client.Region</span></p>
            }
            else
            {
                <p class="text-muted">Client information not available</p>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card">
            <h5><i class="fas fa-info-circle me-2 text-primary"></i>Contract Information</h5>
            <hr>
            <p><strong>Contract ID:</strong> #@Model.ContractId</p>
            <p><strong>Start Date:</strong> @Model.StartDate.ToString("dd MMMM yyyy")</p>
            <p><strong>End Date:</strong> @Model.EndDate.ToString("dd MMMM yyyy")</p>
            <p>
                <strong>Service Level:</strong>
                @if (Model.ServiceLevel == "Premium")
                {
                    <span class="badge-active">Premium</span>
                }
                else if (Model.ServiceLevel == "Standard")
                {
                    <span class="badge bg-info">Standard</span>
                }
                else
                {
                    <span>@Model.ServiceLevel</span>
                }
            </p>
            <p>
                <strong>Status:</strong>
                @if (Model.Status == "Active")
                {
                    <span class="badge-active"><i class="fas fa-check-circle me-1"></i>Active</span>
                }
                else if (Model.Status == "Draft")
                {
                    <span class="badge-draft"><i class="fas fa-pencil-alt me-1"></i>Draft</span>
                }
                else if (Model.Status == "Expired")
                {
                    <span class="badge-expired"><i class="fas fa-times-circle me-1"></i>Expired</span>
                }
                else if (Model.Status == "OnHold")
                {
                    <span class="badge-hold"><i class="fas fa-pause-circle me-1"></i>On Hold</span>
                }
                else
                {
                    <span>@Model.Status</span>
                }
            </p>

            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <div class="mt-3">
                    <a asp-action="DownloadFile" asp-route-id="@Model.ContractId" class="btn-gradient btn-sm">
                        <i class="fas fa-download me-1"></i>Download Signed Agreement
                    </a>
                    <small class="text-muted d-block mt-1">@Model.SignedAgreementFileName</small>
                </div>
            }
            else
            {
                <p class="text-muted mt-2"><i class="fas fa-file-pdf me-1"></i>No PDF uploaded yet</p>
            }
        </div>
    </div>
</div>

<div class="stat-card mt-3">
    <div class="d-flex justify-content-between align-items-center">
        <h5><i class="fas fa-tasks me-2 text-primary"></i>Service Requests</h5>
        @if (Model.Status != "Expired" && Model.Status != "OnHold")
        {
            <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.ContractId" class="btn-gradient btn-sm">
                <i class="fas fa-plus-circle me-1"></i>New Service Request
            </a>
        }
        else
        {
            <span class="text-muted"><i class="fas fa-lock me-1"></i>Cannot create requests - Contract @Model.Status</span>
        }
    </div>
    <hr>

    @if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
    {
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>USD Amount</th>
                        <th>ZAR Amount</th>
                        <th>Rate</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.ServiceRequests.OrderByDescending(r => r.CreatedAt))
                    {
                        <tr>
                            <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>@request.Description</td>
                            <td>$@request.AmountUSD.ToString("N2")</td>
                            <td>R@request.AmountZAR.ToString("N2")</td>
                            <td>@request.ExchangeRateUsed.ToString("N4")</td>
                            <td>
                                @if (request.Status == "Pending")
                                {
                                    <span class="badge-draft">Pending</span>
                                }
                                else if (request.Status == "Completed")
                                {
                                    <span class="badge-active">Completed</span>
                                }
                                else
                                {
                                    <span class="badge-hold">@request.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
            <p class="text-muted">No service requests yet for this contract.</p>
            @if (Model.Status != "Expired" && Model.Status != "OnHold")
            {
                <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.ContractId" class="btn-outline-gradient btn-sm">
                    <i class="fas fa-plus-circle me-1"></i>Create First Request
                </a>
            }
        </div>
    }
</div>