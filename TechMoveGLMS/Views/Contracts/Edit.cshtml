@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
    var clients = ViewBag.Clients as IEnumerable<TechMoveGLMS.Models.Client>;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="text-center mb-4">
            <i class="fas fa-edit fa-3x text-primary"></i>
            <h2 class="mt-2">Edit Contract</h2>
            <p class="text-muted">Update contract information</p>
        </div>

        <div class="stat-card">
            <form asp-action="Edit" enctype="multipart/form-data">
                <input type="hidden" asp-for="ContractId" />
                <input type="hidden" asp-for="SignedAgreementPath" />
                <input type="hidden" asp-for="SignedAgreementFileName" />

                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label fw-bold">Select Client</label>
                    <select asp-for="ClientId" class="form-control form-control-modern" asp-items="@(new SelectList(clients, "ClientId", "Name", Model.ClientId))"></select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control form-control-modern" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control form-control-modern" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ServiceLevel" class="form-label fw-bold">Service Level</label>
                            <select asp-for="ServiceLevel" class="form-control form-control-modern">
                                <option value="Basic">Basic</option>
                                <option value="Standard">Standard</option>
                                <option value="Premium">Premium</option>
                                <option value="Enterprise">Enterprise</option>
                            </select>
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Status</label>
                            <select asp-for="Status" class="form-control form-control-modern">
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                                <option value="Expired">Expired</option>
                                <option value="OnHold">On Hold</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="signedAgreement" class="form-label fw-bold">Upload New PDF (Optional)</label>
                    <input type="file" name="signedAgreement" class="form-control form-control-modern" accept=".pdf" />
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                    {
                        <small class="text-success">Current file: @Model.SignedAgreementFileName</small>
                    }
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Index" class="btn btn-secondary me-md-2">Cancel</a>
                    <button type="submit" class="btn-gradient">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>